{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_TASK_LIST_ID": "lucas-experimentation",
    "ENABLE_LSP_TOOL": "1",
    "GIT_USERNAME": "lucas",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ct notify"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-slack-cookie.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/lgrossi/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "ct tool compaction-recovery"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "uv run ~/.claude/statusline.py",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gt@local": true,
    "commons@local": true,
    "mdp@mollie-claude-plugins": true,
    "pubsub@mollie-claude-plugins": true,
    "skills-forger@mollie-claude-plugins": true,
    "product@mollie-claude-plugins": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "local": {
      "source": {
        "source": "directory",
        "path": "/home/lgrossi/.claude/local-plugins"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "promptSuggestionEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  }
}
